# TripPlanner Backend - Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI APIs ───────────────────────────────────────────────
# Claude API (Anthropic) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API (Google AI) - https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Weather API (free, no key needed) ───────────────────
# Open-Meteo - https://open-meteo.com/ (free, no API key)
WEATHER_API_BASE=https://api.open-meteo.com/v1

# ─── Frontend URL (for CORS) ───────────────────────────────
FRONTEND_URL=http://localhost:5174
